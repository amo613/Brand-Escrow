# ═════════════════════════════════════════════════════════════════════════════
# PactPay — .env.example   (copy to .env ; .env is git-ignored ; PLACEHOLDERS ONLY)
# Backend = secrets. Frontend = only NEXT_PUBLIC_* reach the browser.
# ═════════════════════════════════════════════════════════════════════════════

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# DATABASE_URL = pooled (pgBouncer) → app runtime ; DIRECT_URL = direct → migrations / db push
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── Algorand network (TestNet) ──────────────────────────────────────────────
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
INDEXER_SERVER=https://testnet-idx.algonode.cloud
INDEXER_PORT=443
INDEXER_TOKEN=
NETWORK_CAIP2=algorand:SGO1GKSzyE7IEPItTxCByw9x8FmnrCDexi9/cOUJOiI=

# ─── Assets ──────────────────────────────────────────────────────────────────
USDC_ASA_ID=10458941                 # confirm via facilitator /supported
USDC_DECIMALS=6

# ─── Escrow contract (fill after deploy) ─────────────────────────────────────
ESCROW_APP_ID=
ESCROW_APP_ADDRESS=
CHALLENGE_WINDOW_SECS=60              # demo 60s ; real hours/days
MIN_CONFIDENCE=80                    # 0..100 ; below → no auto-release
MIN_DEAL_MICRO=1000000               # $1.00 minimum

# ─── Backend signers (NEVER client / NEVER commit) ───────────────────────────
AGENT_MNEMONIC=                      # AI oracle: can ONLY attest verdicts
ADMIN_MNEMONIC=                      # bootstrap + dispute arbiter
DISPENSER_MNEMONIC=                  # funds new users with test ALGO + USDC
PLATFORM_TREASURY_ADDR=              # x402 proof-oracle payTo

# ─── New-user airdrop ────────────────────────────────────────────────────────
AIRDROP_ALGO_MICRO=5000000           # 5 ALGO for fees + opt-ins
AIRDROP_USDC_MICRO=50000000          # 50 test USDC

# ─── x402 ────────────────────────────────────────────────────────────────────
FACILITATOR_BASE=https://facilitator.goplausible.xyz
X402_SCHEME=exact
X402_PROOF_PRICE_MICRO=10000         # $0.01 per verification call
AGENT_X402_SPEND_CAP_MICRO=1000000   # max $1.00/hour agent spend

# ─── Data / metrics (post tracking) ──────────────────────────────────────────
APIFY_API_TOKEN=                     # Apify key — TikTok per-post metrics (clockworks scraper)
APIFY_TIKTOK_ACTOR=clockworks~tiktok-scraper

# ─── Admin test console (test without real viral posts) ──────────────────────
NEXT_PUBLIC_ADMIN_ADDR=              # when this wallet logs in → Test Console tab appears
ADMIN_TEST_CONSOLE=true              # allow admin metric injection (turn OFF in prod)

# ─── Login: Web3Auth (Privy-equivalent social login) ─────────────────────────
WEB3AUTH_CLIENT_ID=                  # dashboard.web3auth.io (Sapphire Devnet) — public
WEB3AUTH_NETWORK=sapphire_devnet
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=
NEXT_PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# ─── Creator social VERIFICATION (separate from login) ───────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8080/api/social/x/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/social/youtube/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/api/social/tiktok/callback

# ─── AES token-at-rest + JWT ─────────────────────────────────────────────────
ENCRYPTION_KEY=                      # 32-byte hex for AES-256-GCM
JWT_SECRET=

# ─── LLM (verification) ──────────────────────────────────────────────────────
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=
OPENROUTER_API_KEY=
AI_AUTOAPPROVE_CONFIDENCE=0.80

# ─── Auth / sessions ─────────────────────────────────────────────────────────
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:3000
CHALLENGE_TTL_SECS=300
REDIS_URL=                           # optional; in-memory TTL map ok for demo

# ─── Frontend public config ──────────────────────────────────────────────────
NEXT_PUBLIC_ALGOD_SERVER=https://testnet-api.algonode.cloud
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_ESCROW_APP_ID=
NEXT_PUBLIC_USDC_ASA_ID=10458941
NEXT_PUBLIC_FACILITATOR_BASE=https://facilitator.goplausible.xyz
NEXT_PUBLIC_API_BASE=http://localhost:8080
